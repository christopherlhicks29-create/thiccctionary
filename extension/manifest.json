{
  "manifest_version": 3,
  "name": "Thiccctionary, rate any image",
  "short_name": "Thiccctionary",
  "version": "0.1.0",
  "description": "Right-click any image on the web and receive a thicccness verdict in the dictionary register.",
  "homepage_url": "https://thiccctionary.com/",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Open the Thiccctionary",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": ["contextMenus"],
  "background": {
    "service_worker": "background.js"
  }
}
